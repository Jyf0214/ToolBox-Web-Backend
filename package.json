{
  "name": "backend",
  "version": "1.0.0",
  "description": "ToolBox-Web Backend API Server",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run type-check && npm run lint && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jyf0214/ToolBox-Web-Backend.git"
  },
  "keywords": [
    "toolbox",
    "api",
    "backend"
  ],
  "author": "Jyf0214",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Jyf0214/ToolBox-Web-Backend/issues"
  },
  "homepage": "https://github.com/Jyf0214/ToolBox-Web-Backend#readme",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-validator": "^7.3.1",
    "multer": "1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.7",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "eslint": "8.57.1",
    "eslint-import-resolver-typescript": "3.7.0",
    "eslint-plugin-import": "2.31.0",
    "nodemon": "3.1.9",
    "ts-node": "10.9.2",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
