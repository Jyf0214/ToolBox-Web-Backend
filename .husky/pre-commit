#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 [Backend] Starting Pre-commit Checks..."

# 运行 Lint
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ [Backend] Lint failed. Commit aborted."
  exit 1
fi

# 运行 Build
npm run build
if [ $? -ne 0 ]; then
  echo "❌ [Backend] Build failed. Commit aborted."
  exit 1
fi

echo "✅ [Backend] All checks passed. Proceeding with commit."
exit 0
