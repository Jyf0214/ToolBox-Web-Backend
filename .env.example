# 服务器配置
PORT=7860
NODE_ENV=development

# 数据库配置 (可选，不配置时以无数据库模式运行)
# MySQL/PostgreSQL
DATABASE_URL="mysql://user:password@localhost:3306/toolbox"
# MongoDB
# DATABASE_URL="mongodb://localhost:27017/toolbox"

# 允许的跨域来源 (多个用逗号分隔)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7860

# LibreOffice 路径 (如不在系统路径中)
# LIBREOFFICE_PATH=/usr/bin/libreoffice
